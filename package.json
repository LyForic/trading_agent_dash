{
  "name": "trading_agent_dash",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:editors": "WORLD_V2_ENABLE_EDITOR_API=1 vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "visual:qa": "playwright test -c playwright.visual.config.ts",
    "visual:qa:headed": "playwright test -c playwright.visual.config.ts --headed",
    "visual:qa:record": "VISUAL_QA_VIDEO=1 playwright test -c playwright.visual.config.ts",
    "visual:apex": "playwright test -c playwright.visual.config.ts --grep @apex",
    "visual:town": "playwright test -c playwright.visual.config.ts --grep @town",
    "visual:rooms": "playwright test -c playwright.visual.config.ts --grep @rooms",
    "visual:report": "playwright show-report artifacts/visual/html-report",
    "world-v2:actor-walk-sheets": "node scripts/process_world_v2_actor_walk_sheets.mjs",
    "world-v2:bacon-actor-sources": "node scripts/process_world_v2_bacon_actor_sources.mjs bacon",
    "world-v2:nova-actor-sources": "node scripts/process_world_v2_bacon_actor_sources.mjs nova",
    "world-v2:meridian-actors": "node scripts/process_meridian_generated_actor_sheet.mjs",
    "world-v2:actor-walk-row": "node scripts/process_world_v2_walk_direction_row.mjs",
    "world-v2:compose-walk-markers": "node scripts/compose_world_v2_walk_from_markers.mjs",
    "world-v2:ground-workspace": "node scripts/build_world_v2_ground_workspace.mjs",
    "world-v2:foreground-workspace": "node scripts/build_world_v2_foreground_workspace.mjs",
    "world-v2:manifest-runtime-assets": "node scripts/build_world_v2_foreground_workspace.mjs manifest-runtime --reference-only",
    "world-v2:manifest-runtime-bacon-fullmap-assets": "node scripts/build_world_v2_foreground_workspace.mjs manifest-runtime-bacon-fullmap --reference-only",
    "world-v2:manifest-runtime-time-sprites": "node scripts/build_world_v2_manifest_time_sprites.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "navmesh": "^2.3.1",
    "phaser": "^4.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
